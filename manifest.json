{
  "manifest_version": 3,
  "name": "TypeBridge",
  "version": "0.1.0",
  "description": "Click items from a list to type them as real keystrokes into a web Remote Desktop session — bypasses copy/paste and the Mac/Windows key mismatch.",
  "permissions": ["debugger", "storage", "sidePanel", "tabs"],
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "TypeBridge — open snippet panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": { "default_path": "sidepanel.html" }
}
